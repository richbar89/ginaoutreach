# Copy this file to .env.local and fill in your values

# Microsoft Azure App credentials
# Register your app at https://portal.azure.com -> Azure Active Directory -> App registrations
# Required API permissions: Mail.Send, Mail.ReadWrite (Delegated)
MICROSOFT_CLIENT_ID=your_client_id_here
MICROSOFT_CLIENT_SECRET=your_client_secret_here
MICROSOFT_TENANT_ID=common

# NextAuth - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Cron job secret (used to secure the /api/cron endpoint if you trigger it externally)
CRON_SECRET=your_cron_secret_here
